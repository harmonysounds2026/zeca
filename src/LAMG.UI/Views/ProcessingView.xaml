<UserControl
    x:Class="LAMG.UI.Views.ProcessingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:LAMG.UI.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:ProcessingViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="200" />
            <RowDefinition Height="*" MinHeight="200" />
        </Grid.RowDefinitions>

        <!-- ========================= STATUS + CONTROLS ========================= -->
        <Border
            Grid.Row="0"
            BorderBrush="#D8D8D8"
            BorderThickness="0,0,0,1"
            Padding="0,0,0,12">
            <StackPanel>
                <TextBlock
                    Text="Processing"
                    Style="{StaticResource SectionHeaderStyle}" />

                <Grid Margin="0,4,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Text="{Binding StageDescription}"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0" />
                    <ProgressBar
                        Grid.Column="1"
                        Height="18"
                        Minimum="0"
                        Maximum="1"
                        Value="{Binding OverallFraction, Mode=OneWay}" />
                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
                        <Run Text="{Binding MixesCompleted, Mode=OneWay}" />
                        <Run Text=" / " />
                        <Run Text="{Binding MixesPlanned, Mode=OneWay}" />
                    </TextBlock>
                </Grid>

                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Text="Current mix:"
                        Margin="0,0,6,0"
                        Foreground="#666" />
                    <TextBlock
                        Text="{Binding CurrentMixName, FallbackValue='(none)'}"
                        Margin="0,0,16,0" />
                    <TextBlock
                        Text="Skipped:"
                        Margin="0,0,6,0"
                        Foreground="#666" />
                    <TextBlock
                        Text="{Binding TracksSkipped}"
                        Margin="0,0,16,0" />
                    <TextBlock
                        Text="Elapsed:"
                        Margin="0,0,6,0"
                        Foreground="#666" />
                    <TextBlock Text="{Binding Elapsed}" />
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    Margin="0,12,0,0">
                    <Button
                        Content="Start"
                        Command="{Binding StartCommand}"
                        Padding="20,6"
                        MinWidth="100"
                        FontWeight="SemiBold"
                        Margin="0,0,8,0" />
                    <Button
                        Content="Pause"
                        Command="{Binding PauseCommand}"
                        Padding="14,6"
                        MinWidth="80"
                        Margin="0,0,8,0" />
                    <Button
                        Content="Resume"
                        Command="{Binding ResumeCommand}"
                        Padding="14,6"
                        MinWidth="80"
                        Margin="0,0,8,0" />
                    <Button
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Padding="14,6"
                        MinWidth="80" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ============================== LIVE LOGS ============================== -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,4">
                <Button
                    DockPanel.Dock="Right"
                    Content="Clear"
                    Command="{Binding ClearLogsCommand}"
                    MinWidth="70" />
                <TextBlock
                    Text="Live logs"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" />
            </DockPanel>

            <Border
                Grid.Row="1"
                BorderBrush="#D8D8D8"
                BorderThickness="1"
                Background="#FAFAFA">
                <ListBox
                    ItemsSource="{Binding LogLines}"
                    FontFamily="Consolas"
                    FontSize="12"
                    BorderThickness="0"
                    Background="Transparent"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Text="{Binding Timestamp, StringFormat='HH:mm:ss'}"
                                    Foreground="#888"
                                    Margin="0,0,8,0" />
                                <TextBlock
                                    Text="{Binding Level}"
                                    Width="64"
                                    Foreground="#444"
                                    Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <!-- ============================== RESULTS ============================== -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Text="Completed mixes"
                FontWeight="SemiBold"
                Margin="0,0,0,4" />

            <DataGrid
                Grid.Row="1"
                ItemsSource="{Binding CompletedMixes}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                IsReadOnly="True"
                HeadersVisibility="Column"
                GridLinesVisibility="Horizontal"
                RowHeight="26"
                HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#"        Binding="{Binding IndexInProject}"   Width="50" />
                    <DataGridTextColumn Header="Mode"     Binding="{Binding Mode}"             Width="80" />
                    <DataGridTextColumn Header="File"     Binding="{Binding FileName}"         Width="*" />
                    <DataGridTextColumn Header="Format"   Binding="{Binding OutputFormat}"     Width="80" />
                    <DataGridTextColumn Header="Sec"      Binding="{Binding ActualDurationSec}" Width="70" />
                    <DataGridTextColumn Header="Status"   Binding="{Binding Status}"           Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>

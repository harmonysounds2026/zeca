<Window
    x:Class="LAMG.UI.Views.ShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="clr-namespace:LAMG.UI.Services"
    Title="Longform Audio Mix Generator"
    Height="720"
    Width="1180"
    MinHeight="560"
    MinWidth="900"
    WindowStartupLocation="CenterScreen">

    <DockPanel LastChildFill="True">
        <!-- Sidebar -->
        <StackPanel
            DockPanel.Dock="Left"
            Width="160"
            Background="#F3F3F3">

            <TextBlock
                Text="LAMG"
                FontWeight="Bold"
                FontSize="20"
                Margin="12,16,12,24" />

            <RadioButton
                Style="{StaticResource SidebarButtonStyle}"
                Content="Import"
                IsChecked="{Binding CurrentPage, Mode=OneWay,
                            Converter={StaticResource EnumEqualsConverter},
                            ConverterParameter={x:Static svc:AppPage.Import}}"
                Command="{Binding NavigateToImportCommand}" />

            <RadioButton
                Style="{StaticResource SidebarButtonStyle}"
                Content="Settings"
                IsChecked="{Binding CurrentPage, Mode=OneWay,
                            Converter={StaticResource EnumEqualsConverter},
                            ConverterParameter={x:Static svc:AppPage.Settings}}"
                Command="{Binding NavigateToSettingsCommand}" />

            <RadioButton
                Style="{StaticResource SidebarButtonStyle}"
                Content="Processing"
                IsChecked="{Binding CurrentPage, Mode=OneWay,
                            Converter={StaticResource EnumEqualsConverter},
                            ConverterParameter={x:Static svc:AppPage.Processing}}"
                Command="{Binding NavigateToProcessingCommand}" />
        </StackPanel>

        <!-- Status bar -->
        <Border
            DockPanel.Dock="Bottom"
            Background="#F3F3F3"
            BorderBrush="#D0D0D0"
            BorderThickness="0,1,0,0"
            Padding="10,4">
            <TextBlock Text="{Binding StatusBarText}" />
        </Border>

        <!-- Main content -->
        <ContentControl
            Content="{Binding CurrentViewModel}"
            Margin="12" />
    </DockPanel>
</Window>

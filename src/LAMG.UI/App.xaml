<Application
    x:Class="LAMG.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:LAMG.UI.ViewModels"
    xmlns:views="clr-namespace:LAMG.UI.Views"
    ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Implicit view resolution. ContentControl.Content = ViewModel
                 instance, WPF picks the matching DataTemplate by type. -->
            <DataTemplate DataType="{x:Type vm:ImportViewModel}">
                <views:ImportView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ProcessingViewModel}">
                <views:ProcessingView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
